{
  "name": "工作汇报格式",
  "version": "1.0",
  "description": "职场专业工作汇报格式（年终总结、述职报告、项目总结等）",
  "page": {
    "margin_top_mm": 25.4,
    "margin_bottom_mm": 25.4,
    "margin_left_mm": 31.8,
    "margin_right_mm": 31.8,
    "paper_size": "A4",
    "header_distance_mm": 15,
    "footer_distance_mm": 17
  },
  "levels": {
    "title": {
      "font_main": "方正小标宋简体",
      "font_number": "Arial Black",
      "font_size_pt": 22,
      "bold": true,
      "italic": false,
      "underline": false,
      "line_spacing_type": "exactly",
      "line_spacing_value": 28,
      "space_before_lines": 1,
      "space_after_lines": 1,
      "first_line_indent_chars": 0,
      "alignment": "center",
      "keep_with_next": false,
      "page_break_before": false
    },
    "heading_1": {
