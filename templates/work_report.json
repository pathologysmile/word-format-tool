  "header": {
    "text": "202X年度工作汇报",
    "font_main": "宋体",
    "font_number": "Times New Roman",
    "font_size_pt": 9,
    "alignment": "center"
  },
  "footer": {
    "text": "第 {page} 页 / 共 {numpages} 页",
    "font_main": "宋体",
    "font_number": "Times New Roman",
    "font_size_pt": 9,
    "alignment": "center"
  },
  "table": {
    "font_main": "仿宋_GB2312",
    "font_number": "Times New Roman",
    "font_size_pt": 14,
    "alignment": "center",
    "cell_alignment": "center",
    "header_bg_color": "D9D9D9",
    "header_bold": true,
    "border_style": "thin"
