      "font_number": "Arial",
      "font_size_pt": 16,
      "bold": true,
      "italic": false,
      "underline": false,
      "line_spacing_type": "exactly",
      "line_spacing_value": 28,
      "space_before_lines": 0.5,
      "space_after_lines": 0.5,
      "first_line_indent_chars": 0,
      "alignment": "left",
      "keep_with_next": false,
      "page_break_before": false
    },
    "heading_2": {
      "font_main": "楷体_GB2312",
      "font_number": "Times New Roman",
      "font_size_pt": 16,
      "bold": true,
      "italic": false,
      "underline": false,
      "line_spacing_type": "exactly",
      "line_spacing_value": 28,
      "space_before_lines": 0.5,
      "space_after_lines": 0.5,
      "first_line_indent_chars": 0,
      "alignment": "left",
      "keep_with_next": false,
      "page_break_before": false
    },
    "heading_3": {
      "font_main": "仿宋_GB2312",
      "font_number": "Times New Roman",
      "font_size_pt": 16,
      "bold": true,
      "italic": false,
      "underline": false,
      "line_spacing_type": "exactly",
      "line_spacing_value": 28,
      "space_before_lines": 0,
      "space_after_lines": 0,
      "first_line_indent_chars": 0,
      "alignment": "left",
      "keep_with_next": false,
      "page_break_before": false
    },
    "heading_4": {
      "font_main": "仿宋_GB2312",
      "font_number": "Times New Roman",
      "font_size_pt": 16,
      "bold": false,
      "italic": false,
      "underline": false,
      "line_spacing_type": "exactly",
      "line_spacing_value": 28,
      "space_before_lines": 0,
      "space_after_lines": 0,
      "first_line_indent_chars": 0,
      "alignment": "left",
      "keep_with_next": false,
      "page_break_before": false
    },
    "body": {
      "font_main": "仿宋_GB2312",
      "font_number": "Times New Roman",
      "font_size_pt": 16,
      "bold": false,
      "italic": false,
      "underline": false,
      "line_spacing_type": "exactly",
      "line_spacing_value": 28,
      "space_before_lines": 0,
      "space_after_lines": 0.5,
      "first_line_indent_chars": 2,
      "alignment": "justify",
      "keep_with_next": false,
      "page_break_before": false
