{
  "name": "学术论文格式",
  "version": "1.0",
  "description": "适用于学位论文、期刊文章",
  "page": {
    "margin_top_mm": 25,
    "margin_bottom_mm": 25,
    "margin_left_mm": 25,
    "margin_right_mm": 25,
    "paper_size": "A4",
    "header_distance_mm": 15,
    "footer_distance_mm": 17
  },
  "levels": {
    "title": {
      "font_main": "黑体",
      "font_size_pt": 18,
      "bold": true,
      "italic": false,
      "underline": false,
      "line_spacing_type": "multiple",
      "line_spacing_value": 1.5,
      "space_before_pt": 24,
      "space_after_pt": 18,
      "first_line_indent_chars": 0,
      "alignment": "center",
      "keep_with_next": false,
      "page_break_before": false
    },
    "heading_1": {
      "font_main": "黑体",
      "font_size_pt": 14,
      "bold": true,
      "italic": false,
      "underline": false,
      "line_spacing_type": "multiple",
      "line_spacing_value": 1.5,
      "space_before_pt": 18,
      "space_after_pt": 12,
      "first_line_indent_chars": 0,
      "alignment": "left",
      "keep_with_next": false,
      "page_break_before": false
    },
    "heading_2": {
      "font_main": "宋体",
      "font_size_pt": 12,
      "bold": true,
      "italic": false,
      "underline": false,
      "line_spacing_type": "multiple",
      "line_spacing_value": 1.5,
      "space_before_pt": 12,
      "space_after_pt": 6,
      "first_line_indent_chars": 0,
      "alignment": "left",
      "keep_with_next": false,
      "page_break_before": false
    },
    "heading_3": {
      "font_main": "宋体",
      "font_size_pt": 12,
      "bold": false,
      "italic": false,
      "underline": false,
      "line_spacing_type": "multiple",
      "line_spacing_value": 1.5,
      "space_before_pt": 6,
      "space_after_pt": 0,
      "first_line_indent_chars": 0,
      "alignment": "left",
      "keep_with_next": false,
      "page_break_before": false
    },
    "heading_4": {
      "font_main": "宋体",
      "font_size_pt": 12,
      "bold": false,
      "italic": false,
      "underline": false,
      "line_spacing_type": "multiple",
      "line_spacing_value": 1.5,
      "space_before_pt": 0,
      "space_after_pt": 0,
      "first_line_indent_chars": 0,
      "alignment": "left",
      "keep_with_next": false,
      "page_break_before": false
    },
    "body": {
      "font_main": "宋体",
      "font_size_pt": 12,
      "bold": false,
      "italic": false,
      "underline": false,
      "line_spacing_type": "multiple",
      "line_spacing_value": 1.5,
      "space_before_pt": 0,
      "space_after_pt": 0,
      "first_line_indent_chars": 2,
      "alignment": "justify",
      "keep_with_next": false,
      "page_break_before": false
    }
  },
  "header_config": {
    "enabled": false
  }
}
